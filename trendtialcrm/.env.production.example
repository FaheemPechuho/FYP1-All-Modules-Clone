# ============================================================
# TrendtialCRM — Vercel Production Environment Variables
# ============================================================
# Copy these keys into the Vercel project dashboard under:
#   Settings → Environment Variables → Production
#
# DO NOT commit real values to git.
# ============================================================

# Clara Backend URL (your Render.com deployed backend)
VITE_CLARA_BACKEND_URL=https://clara-backend.onrender.com

# Supabase (same as local — it's already cloud)
VITE_SUPABASE_URL=https://qgzngizgcdjomscontuk.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Google Sheets (optional)
VITE_GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
VITE_SHEET_ID=your_sheet_id_here
